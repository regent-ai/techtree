# -----------------------------------------------------------------------------
# TechTree environment example
# Copy to `.env` and replace placeholder values.
# -----------------------------------------------------------------------------
#
# Quick generation helpers:
#   SECRET_KEY_BASE:          mix phx.gen.secret
#   INTERNAL_SHARED_SECRET:   openssl rand -hex 32
#   SIWA_SHARED_SECRET:       openssl rand -hex 32
#   SIWA_HMAC_SECRET:         openssl rand -hex 32
#   SIWA_RECEIPT_SECRET:      openssl rand -hex 32
#   ANVIL_PRIVATE_KEY:        cast wallet new --unsafe-password '' | rg 'Private key' -N

# -----------------------------------------------------------------------------
# Phoenix app (dev/test defaults)
# -----------------------------------------------------------------------------
DB_USER=postgres
DB_PASS=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tech_tree_dev

# Optional Postgres fallbacks (if you prefer PG* vars)
# PGUSER=postgres
# PGPASSWORD=
# PGHOST=localhost
# PGPORT=5432

# -----------------------------------------------------------------------------
# Phoenix runtime / release
# -----------------------------------------------------------------------------
PHX_SERVER=true
PORT=4000
PHX_HOST=localhost
SECRET_KEY_BASE=replace_with_mix_phx_gen_secret_output
POOL_SIZE=10
ECTO_IPV6=false
DATABASE_URL=ecto://postgres:@localhost/tech_tree_dev
# Optional (Neon/pgbouncer): use unpooled URL for migrations.
DATABASE_URL_UNPOOLED=
DNS_CLUSTER_QUERY=

# -----------------------------------------------------------------------------
# Core infra + app config
# -----------------------------------------------------------------------------
DRAGONFLY_HOST=localhost
DRAGONFLY_PORT=6379
SYSTEM_AGENT_ID=1
INTERNAL_SHARED_SECRET=replace_with_internal_shared_secret

# -----------------------------------------------------------------------------
# Privy JWT verification for human-authenticated routes
# -----------------------------------------------------------------------------
PRIVY_APP_ID=replace_with_privy_app_id
PRIVY_APP_SECRET=replace_with_privy_app_secret
PRIVY_VERIFICATION_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----

# -----------------------------------------------------------------------------
# SIWA sidecar integration (Phoenix -> sidecar)
# NOTE: SIWA_SHARED_SECRET should match SIWA_HMAC_SECRET in sidecar.
# -----------------------------------------------------------------------------
SIWA_INTERNAL_URL=http://localhost:4100
SIWA_SHARED_SECRET=replace_with_shared_hmac_secret
SIWA_HMAC_SECRET=replace_with_shared_hmac_secret
SIWA_HMAC_KEY_ID=sidecar-internal-v1

# -----------------------------------------------------------------------------
# Lighthouse IPFS
# -----------------------------------------------------------------------------
LIGHTHOUSE_API_KEY=replace_with_lighthouse_api_key
LIGHTHOUSE_BASE_URL=https://upload.lighthouse.storage
LIGHTHOUSE_GATEWAY_BASE=https://gateway.lighthouse.storage/ipfs
LIGHTHOUSE_STORAGE_TYPE=annual

# -----------------------------------------------------------------------------
# SIWA sidecar service (services/siwa-sidecar)
# -----------------------------------------------------------------------------
SIWA_PORT=4100
SIWA_NONCE_TTL_SECONDS=300
SIWA_RECEIPT_TTL_SECONDS=900
SIWA_RECEIPT_SECRET=replace_with_receipt_signing_secret
SIWA_HMAC_MAX_SKEW_SECONDS=300
SIWA_HTTP_MAX_AGE_SECONDS=300
SIWA_HTTP_CREATED_DRIFT_SECONDS=5
SIWA_HTTP_REPLAY_TTL_SECONDS=300

# -----------------------------------------------------------------------------
# XMTP worker service (services/xmtp-worker)
# -----------------------------------------------------------------------------
PHOENIX_INTERNAL_URL=http://localhost:4000/api/internal
XMTP_CANONICAL_ROOM_KEY=public-trollbox
XMTP_CANONICAL_ROOM_NAME=Tech Tree Trollbox
XMTP_CANONICAL_ROOM_GROUP_ID=xmtp-public-trollbox
XMTP_ENV=dev
XMTP_WALLET_PRIVATE_KEY=replace_with_64_byte_hex_private_key
XMTP_DB_ENCRYPTION_KEY=replace_with_32_plus_char_db_encryption_secret
XMTP_SDK_MODULE=@xmtp/node-sdk
XMTP_ETHERS_MODULE=ethers
XMTP_CREATE_GROUP_IF_MISSING=true
XMTP_REQUIRE_CONSENT=false
XMTP_CONSENT_PROOF_ENDPOINT=
XMTP_POLL_INTERVAL_MS=5000
XMTP_REQUEST_TIMEOUT_MS=10000

# Optional endpoint overrides
XMTP_ROOM_LOOKUP_ENDPOINT=http://localhost:4000/api/internal/xmtp/rooms/:roomKey
XMTP_ROOM_UPSERT_ENDPOINT=http://localhost:4000/api/internal/xmtp/rooms/upsert
XMTP_MIRROR_ENDPOINT=http://localhost:4000/api/internal/xmtp/messages/upsert
XMTP_LEASE_MEMBERSHIP_ENDPOINT=http://localhost:4000/api/internal/xmtp/commands/lease
XMTP_COMPLETE_MEMBERSHIP_ENDPOINT_TEMPLATE=http://localhost:4000/api/internal/xmtp/commands/:id/complete
XMTP_FAIL_MEMBERSHIP_ENDPOINT_TEMPLATE=http://localhost:4000/api/internal/xmtp/commands/:id/fail

# -----------------------------------------------------------------------------
# Contracts deploy (contracts/script/DeployTechTreeRegistry.s.sol)
# -----------------------------------------------------------------------------
TECHTREE_BASE_MODE=auto
BASE_RPC_URL=http://127.0.0.1:8545
TECHTREE_CHAIN_ID=8453
# Preferred env name for runtime contract address:
REGISTRY_CONTRACT_ADDRESS=replace_with_registry_contract_address
# Legacy alias still supported in config for local convenience:
TECHTREE_REGISTRY=replace_with_registry_address
REGISTRY_WRITER_PRIVATE_KEY=replace_with_registry_writer_private_key
CAST_BIN=cast

DEPLOY_TARGET=anvil
ANVIL_RPC_URL=http://127.0.0.1:8545
ANVIL_PRIVATE_KEY=replace_with_anvil_private_key
BASE_SEPOLIA_RPC_URL=replace_with_base_sepolia_rpc_url
BASE_SEPOLIA_PRIVATE_KEY=replace_with_base_sepolia_private_key
REGISTRY_ADMIN=
REGISTRY_INITIAL_WRITER=

# -----------------------------------------------------------------------------
# QA/browser harness overrides (qa/phase-c-smoke.sh + qa/phase-d-browser-e2e.sh)
# -----------------------------------------------------------------------------
PLAYWRIGHT_VERSION=1.58.2
IOS_DEVICE=iPhone 15 Pro
REQUIRE_DESKTOP=1
REQUIRE_IOS=0

# -----------------------------------------------------------------------------
# Test-only partitioning
# -----------------------------------------------------------------------------
MIX_TEST_PARTITION=

# -----------------------------------------------------------------------------
# Shell-safe overrides (for `set -a; source .env; set +a`)
# Place these at the bottom of your real `.env` if you source it in zsh/bash.
# -----------------------------------------------------------------------------
PRIVY_VERIFICATION_KEY=$'-----BEGIN PUBLIC KEY-----\nreplace_with_base64_key_material\n-----END PUBLIC KEY-----'
XMTP_CANONICAL_ROOM_NAME="Tech Tree Trollbox"
IOS_DEVICE="iPhone 15 Pro"

# -----------------------------------------------------------------------------
# Required for real XMTP worker (quick-copy block)
# -----------------------------------------------------------------------------
XMTP_TRANSPORT_MODE=real
XMTP_ENV=dev
PHOENIX_INTERNAL_URL=http://localhost:4000/api/internal
INTERNAL_SHARED_SECRET=replace_with_internal_shared_secret
XMTP_WALLET_PRIVATE_KEY=replace_with_64_byte_hex_private_key
XMTP_DB_ENCRYPTION_KEY=replace_with_32_plus_char_db_encryption_secret
