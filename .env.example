# -----------------------------------------------------------------------------
# TechTree full-local parity environment
# Copy to `.env.local`, replace placeholder values, then run:
#   direnv allow
#   ./scripts/dev_full_setup.sh
#   ./scripts/dev_full_start.sh
# -----------------------------------------------------------------------------
#
# Quick generation helpers:
#   SECRET_KEY_BASE:        mix phx.gen.secret
#   INTERNAL_SHARED_SECRET: openssl rand -hex 32
#   SIWA_SHARED_SECRET:     openssl rand -hex 32
#   SIWA_RECEIPT_SECRET:    openssl rand -hex 32

# -----------------------------------------------------------------------------
# Local infra
# -----------------------------------------------------------------------------
export DB_USER=postgres
export DB_PASS=
export DB_HOST=localhost
export DB_PORT=5432
export DB_NAME=tech_tree_dev
export LOCAL_DATABASE_URL=ecto://postgres:@localhost/tech_tree_dev

# -----------------------------------------------------------------------------
# Phoenix app
# -----------------------------------------------------------------------------
export PORT=4001
export PHX_HOST=localhost
export SECRET_KEY_BASE=replace_with_mix_phx_gen_secret_output
export ECTO_POOL_SIZE=10
export SYSTEM_AGENT_ID=1
export INTERNAL_SHARED_SECRET=replace_with_internal_shared_secret

# -----------------------------------------------------------------------------
# Privy human auth
# -----------------------------------------------------------------------------
export PRIVY_APP_ID=replace_with_privy_app_id
export PRIVY_VERIFICATION_KEY=$'-----BEGIN PUBLIC KEY-----\nreplace_with_base64_key_material\n-----END PUBLIC KEY-----'

# -----------------------------------------------------------------------------
# SIWA integration
# -----------------------------------------------------------------------------
export SIWA_INTERNAL_URL=http://localhost:4100
export SIWA_SHARED_SECRET=replace_with_shared_hmac_secret
export SIWA_HMAC_SECRET="${SIWA_SHARED_SECRET}"
export SIWA_HMAC_KEY_ID=sidecar-internal-v1

# -----------------------------------------------------------------------------
# SIWA sidecar
# -----------------------------------------------------------------------------
export SIWA_PORT=4100
export SIWA_NONCE_TTL_SECONDS=300
export SIWA_RECEIPT_TTL_SECONDS=900
export SIWA_RECEIPT_SECRET=replace_with_receipt_signing_secret
export SIWA_HMAC_MAX_SKEW_SECONDS=300
export SIWA_HTTP_MAX_AGE_SECONDS=300
export SIWA_HTTP_CREATED_DRIFT_SECONDS=5
export SIWA_HTTP_REPLAY_TTL_SECONDS=300

# -----------------------------------------------------------------------------
# Lighthouse IPFS
# -----------------------------------------------------------------------------
export LIGHTHOUSE_API_KEY=replace_with_lighthouse_api_key
export LIGHTHOUSE_BASE_URL=https://upload.lighthouse.storage
export LIGHTHOUSE_GATEWAY_BASE=https://gateway.lighthouse.storage/ipfs
export LIGHTHOUSE_STORAGE_TYPE=annual

# -----------------------------------------------------------------------------
# Base Sepolia registry publishing config
# -----------------------------------------------------------------------------
export TECHTREE_ETHEREUM_MODE=rpc
export BASE_SEPOLIA_RPC_URL=replace_with_base_sepolia_rpc_url
export TECHTREE_CHAIN_ID=84532
export REGISTRY_CONTRACT_ADDRESS=replace_with_registry_contract_address
export REGISTRY_WRITER_PRIVATE_KEY=replace_with_registry_writer_private_key
export CAST_BIN=cast

# -----------------------------------------------------------------------------
# Base Sepolia paid node settlement config
# -----------------------------------------------------------------------------
export AUTOSKILL_BASE_SEPOLIA_SETTLEMENT_CONTRACT=replace_with_content_settlement_contract_address
export AUTOSKILL_BASE_SEPOLIA_USDC_TOKEN=replace_with_base_sepolia_usdc_or_test_usdc_address
export AUTOSKILL_BASE_SEPOLIA_TREASURY_ADDRESS=replace_with_treasury_wallet_address
