# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where 3rd-party dependencies like ExDoc output generated docs.
/doc/

# Ignore .fetch files in case you like to edit your project deps locally.
/.fetch

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Temporary files, for example, from tests.
/tmp/

# Ignore package tarball (built via "mix hex.build").
tech_tree-*.tar

# Ignore assets that are produced by build tools.
/priv/static/assets/

# Ignore digested assets cache.
/priv/static/cache_manifest.json

# env vars
.env
.env.local
.env.*.local

# In case you use Node.js/npm, you want to ignore these.
npm-debug.log
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log
*.tsbuildinfo
*.DS_Store
/assets/node_modules/
/.turbo/

# Foundry generated outputs
/contracts/out/
/contracts/cache/

# Service build and dependency artifacts
/services/node_modules/
/services/*/node_modules/
/services/siwa-sidecar/dist/
/services/xmtp-worker/dist/
/services/*/*.tsbuildinfo

# QA local/browser runtime artifacts
/qa/.agent-browser/
/qa/.agent-browser-home/
/qa/runtime-home/
/qa/artifacts/
audit/

# Local orchestration scaffolding
/.claude/
/.codex/
/WORKFLOW.md
/scripts/check_docs.sh

# Local-only or intentionally untracked repo artifacts
/services/xmtp-worker/node_modules/
/skills/
/codeplan.md
/contracts/regent_techtree_v1_redline_spec.md
/regent-cli-and-runtime-spec.md
/techtree-v001-revised-spec.md
/docs/bbh/*
/platform/*.md
/qa/*.md

# Editor and local tool noise
.idea/
.vscode/
.elixir_ls/
.lexical/
/coverage/
/playwright-report/
/test-results/
