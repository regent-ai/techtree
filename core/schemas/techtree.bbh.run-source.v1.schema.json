{
  "$defs": {
    "ArtifactManifestEntry": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "enum": [
            "workspace_file",
            "generated_output",
            "report",
            "checkpoint_pointer",
            "data_file"
          ],
          "title": "Kind",
          "type": "string"
        },
        "path": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Path",
          "type": "string"
        },
        "required_for_validation": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Required For Validation"
        },
        "sha256": {
          "pattern": "^sha256:[0-9a-f]{64}$",
          "title": "Sha256",
          "type": "string"
        },
        "size_bytes": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Size Bytes"
        }
      },
      "required": [
        "path",
        "kind",
        "sha256"
      ],
      "title": "ArtifactManifestEntry",
      "type": "object"
    },
    "BbhRunProfile": {
      "additionalProperties": false,
      "properties": {
        "assignment_ref": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Assignment Ref"
        },
        "child_genome_ref": {
          "anyOf": [
            {
              "maxLength": 256,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Child Genome Ref"
        },
        "genome_ref": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Genome Ref",
          "type": "string"
        },
        "keep_decision": {
          "$ref": "#/$defs/KeepDecision",
          "default": "pending"
        },
        "notes": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Notes"
        },
        "parent_genome_ref": {
          "anyOf": [
            {
              "maxLength": 256,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Parent Genome Ref"
        },
        "provider": {
          "$ref": "#/$defs/Provider"
        },
        "split": {
          "$ref": "#/$defs/Split"
        }
      },
      "required": [
        "split",
        "genome_ref",
        "provider"
      ],
      "title": "BbhRunProfile",
      "type": "object"
    },
    "EvaluatorKind": {
      "enum": [
        "hypotest"
      ],
      "title": "EvaluatorKind",
      "type": "string"
    },
    "HarnessType": {
      "enum": [
        "openclaw",
        "hermes",
        "claude_code",
        "custom"
      ],
      "title": "HarnessType",
      "type": "string"
    },
    "KeepDecision": {
      "enum": [
        "keep",
        "discard",
        "pending"
      ],
      "title": "KeepDecision",
      "type": "string"
    },
    "Provider": {
      "enum": [
        "bbh",
        "bbh_train",
        "techtree"
      ],
      "title": "Provider",
      "type": "string"
    },
    "RunEvaluator": {
      "additionalProperties": false,
      "properties": {
        "benchmark_ref": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Benchmark Ref"
        },
        "dataset_ref": {
          "minLength": 1,
          "title": "Dataset Ref",
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/EvaluatorKind"
        },
        "scorer_version": {
          "minLength": 1,
          "title": "Scorer Version",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "dataset_ref",
        "scorer_version"
      ],
      "title": "RunEvaluator",
      "type": "object"
    },
    "RunExecutor": {
      "additionalProperties": false,
      "properties": {
        "harness": {
          "$ref": "#/$defs/HarnessType"
        },
        "harness_version": {
          "maxLength": 64,
          "minLength": 1,
          "title": "Harness Version",
          "type": "string"
        },
        "id": {
          "anyOf": [
            {
              "maxLength": 256,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Id"
        },
        "profile": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Profile"
        },
        "type": {
          "enum": [
            "genome",
            "actor",
            "system"
          ],
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "type",
        "harness",
        "harness_version"
      ],
      "title": "RunExecutor",
      "type": "object"
    },
    "RunInstance": {
      "additionalProperties": false,
      "properties": {
        "family_ref": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Family Ref"
        },
        "instance_ref": {
          "minLength": 1,
          "title": "Instance Ref",
          "type": "string"
        },
        "seed": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Seed"
        }
      },
      "required": [
        "instance_ref"
      ],
      "title": "RunInstance",
      "type": "object"
    },
    "RunOrigin": {
      "additionalProperties": false,
      "properties": {
        "transport": {
          "default": "local",
          "enum": [
            "local",
            "xmtp",
            "gossipsub",
            "api"
          ],
          "title": "Transport",
          "type": "string"
        },
        "trigger": {
          "default": "manual",
          "enum": [
            "manual",
            "assignment",
            "validator",
            "automation"
          ],
          "title": "Trigger",
          "type": "string"
        },
        "workload": {
          "const": "bbh",
          "default": "bbh",
          "title": "Workload",
          "type": "string"
        }
      },
      "title": "RunOrigin",
      "type": "object"
    },
    "RunPaths": {
      "additionalProperties": false,
      "properties": {
        "analysis_path": {
          "default": "analysis.py",
          "maxLength": 512,
          "minLength": 1,
          "title": "Analysis Path",
          "type": "string"
        },
        "best_program_path": {
          "anyOf": [
            {
              "maxLength": 512,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": "outputs/skydiscover/best_program.py",
          "title": "Best Program Path"
        },
        "best_solution_patch_path": {
          "anyOf": [
            {
              "maxLength": 512,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": "outputs/skydiscover/best_solution.patch",
          "title": "Best Solution Patch Path"
        },
        "checkpoint_pointer_path": {
          "anyOf": [
            {
              "maxLength": 512,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": "outputs/skydiscover/latest_checkpoint.txt",
          "title": "Checkpoint Pointer Path"
        },
        "evaluator_artifacts_path": {
          "anyOf": [
            {
              "maxLength": 512,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": "outputs/skydiscover/evaluator_artifacts.json",
          "title": "Evaluator Artifacts Path"
        },
        "evaluator_path": {
          "anyOf": [
            {
              "maxLength": 512,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": "eval/hypotest_skydiscover.py",
          "title": "Evaluator Path"
        },
        "final_answer_path": {
          "anyOf": [
            {
              "maxLength": 512,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": "final_answer.md",
          "title": "Final Answer Path"
        },
        "genome_path": {
          "anyOf": [
            {
              "maxLength": 512,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": "genome.source.yaml",
          "title": "Genome Path"
        },
        "log_path": {
          "anyOf": [
            {
              "maxLength": 512,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": "outputs/run.log",
          "title": "Log Path"
        },
        "report_path": {
          "anyOf": [
            {
              "maxLength": 512,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": "outputs/report.html",
          "title": "Report Path"
        },
        "search_config_path": {
          "anyOf": [
            {
              "maxLength": 512,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": "search.config.yaml",
          "title": "Search Config Path"
        },
        "search_log_path": {
          "anyOf": [
            {
              "maxLength": 512,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": "outputs/skydiscover/search.log",
          "title": "Search Log Path"
        },
        "search_summary_path": {
          "anyOf": [
            {
              "maxLength": 512,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": "outputs/skydiscover/search_summary.json",
          "title": "Search Summary Path"
        },
        "seed_program_path": {
          "anyOf": [
            {
              "maxLength": 512,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": "solver/initial_program.py",
          "title": "Seed Program Path"
        },
        "verdict_path": {
          "default": "outputs/verdict.json",
          "maxLength": 512,
          "minLength": 1,
          "title": "Verdict Path",
          "type": "string"
        }
      },
      "title": "RunPaths",
      "type": "object"
    },
    "RunScore": {
      "additionalProperties": false,
      "properties": {
        "normalized": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Normalized",
          "type": "number"
        },
        "raw": {
          "title": "Raw",
          "type": "number"
        },
        "scorer_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Scorer Version"
        }
      },
      "required": [
        "raw",
        "normalized"
      ],
      "title": "RunScore",
      "type": "object"
    },
    "RunSearch": {
      "additionalProperties": false,
      "properties": {
        "algorithm": {
          "minLength": 1,
          "title": "Algorithm",
          "type": "string"
        },
        "budget": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Budget"
        },
        "checkpoint_ref": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Checkpoint Ref"
        },
        "summary": {
          "anyOf": [
            {
              "$ref": "#/$defs/RunSearchSummary"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "algorithm"
      ],
      "title": "RunSearch",
      "type": "object"
    },
    "RunSearchSummary": {
      "additionalProperties": false,
      "properties": {
        "artifact_keys": {
          "items": {
            "type": "string"
          },
          "title": "Artifact Keys",
          "type": "array"
        },
        "best_iteration": {
          "minimum": 0,
          "title": "Best Iteration",
          "type": "integer"
        },
        "best_score": {
          "title": "Best Score",
          "type": "number"
        },
        "checkpoint_ref": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Checkpoint Ref"
        },
        "elapsed_ms": {
          "minimum": 0,
          "title": "Elapsed Ms",
          "type": "integer"
        },
        "iterations_completed": {
          "minimum": 0,
          "title": "Iterations Completed",
          "type": "integer"
        },
        "iterations_requested": {
          "minimum": 1,
          "title": "Iterations Requested",
          "type": "integer"
        },
        "total_evaluations": {
          "minimum": 0,
          "title": "Total Evaluations",
          "type": "integer"
        }
      },
      "required": [
        "best_score",
        "best_iteration",
        "iterations_requested",
        "iterations_completed",
        "total_evaluations",
        "elapsed_ms"
      ],
      "title": "RunSearchSummary",
      "type": "object"
    },
    "RunSolver": {
      "additionalProperties": false,
      "properties": {
        "entrypoint": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Entrypoint"
        },
        "kind": {
          "$ref": "#/$defs/SolverKind"
        }
      },
      "required": [
        "kind"
      ],
      "title": "RunSolver",
      "type": "object"
    },
    "RunStatus": {
      "enum": [
        "created",
        "running",
        "completed",
        "failed"
      ],
      "title": "RunStatus",
      "type": "string"
    },
    "SolverKind": {
      "enum": [
        "hermes",
        "openclaw",
        "skydiscover"
      ],
      "title": "SolverKind",
      "type": "string"
    },
    "Split": {
      "enum": [
        "climb",
        "benchmark",
        "challenge",
        "draft"
      ],
      "title": "Split",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "artifact_manifest": {
      "items": {
        "$ref": "#/$defs/ArtifactManifestEntry"
      },
      "title": "Artifact Manifest",
      "type": "array"
    },
    "artifact_ref": {
      "maxLength": 256,
      "minLength": 1,
      "title": "Artifact Ref",
      "type": "string"
    },
    "bbh": {
      "$ref": "#/$defs/BbhRunProfile"
    },
    "evaluator": {
      "$ref": "#/$defs/RunEvaluator"
    },
    "executor": {
      "$ref": "#/$defs/RunExecutor"
    },
    "instance": {
      "$ref": "#/$defs/RunInstance"
    },
    "notes": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Notes"
    },
    "origin": {
      "$ref": "#/$defs/RunOrigin"
    },
    "paths": {
      "$ref": "#/$defs/RunPaths"
    },
    "schema_version": {
      "const": "techtree.bbh.run-source.v1",
      "default": "techtree.bbh.run-source.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "score": {
      "anyOf": [
        {
          "$ref": "#/$defs/RunScore"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "search": {
      "anyOf": [
        {
          "$ref": "#/$defs/RunSearch"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "solver": {
      "$ref": "#/$defs/RunSolver"
    },
    "status": {
      "$ref": "#/$defs/RunStatus",
      "default": "created"
    }
  },
  "required": [
    "artifact_ref",
    "executor",
    "solver",
    "instance",
    "evaluator",
    "bbh"
  ],
  "title": "BbhRunSourceV1",
  "type": "object"
}
