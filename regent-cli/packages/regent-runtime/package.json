{
  "name": "@regent/runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "@regent/types": "workspace:*",
    "@xmtp/cli": "^0.2.0",
    "viem": "^2.38.2",
    "zod": "^4.1.11"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:integration": "REGENT_ENABLE_NETWORK_TESTS=1 vitest run",
    "test:live": "REGENT_ENABLE_NETWORK_TESTS=1 REGENT_INTEGRATION=1 vitest run test/techtree.integration.test.ts",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  }
}
