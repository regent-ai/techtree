web: bash -lc 'set -euo pipefail; [[ -f .env.local ]] || { echo "Missing .env.local. Copy .env.example to .env.local first." >&2; exit 1; }; set -a; source .env.local; set +a; exec mix phx.server'
siwa: bash -lc 'set -euo pipefail; [[ -f .env.local ]] || { echo "Missing .env.local. Copy .env.example to .env.local first." >&2; exit 1; }; set -a; source .env.local; set +a; cd services; exec bun run dev:siwa'
